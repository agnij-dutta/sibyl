# ─── PostgreSQL (Neon or local) ───────────────────────
DATABASE_URL=postgresql://sibyl:sibyl_dev@localhost:5432/sibyl

# ─── ClickHouse (telemetry storage) ──────────────────
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DATABASE=sibyl
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=

# ─── Redis (caching, pub/sub) ────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Qdrant (vector search) ─────────────────────────
QDRANT_URL=http://localhost:6333

# ─── Google Gemini (AI reasoning + embeddings) ──────
GEMINI_API_KEY=

# ─── Auth ────────────────────────────────────────────
JWT_SECRET=sibyl-dev-secret-change-in-production

# ─── Ingest Service ─────────────────────────────────
PORT=3001

# ─── Public (Next.js client-side) ───────────────────
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_INGEST_URL=http://localhost:3001

# ─── Node environment ───────────────────────────────
NODE_ENV=development
